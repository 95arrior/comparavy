# ─── Anthropic (글 생성 엔진) ───────────────────────────────
ANTHROPIC_API_KEY=
# 사용 모델 (기본값: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# ─── Supabase (인증 · DB) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 (절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# ─── 토스페이먼츠 빌링 (자동결제) ───────────────────────────
# 테스트 키로 개발 가능. 클라이언트 키만 NEXT_PUBLIC_ 허용.
NEXT_PUBLIC_TOSS_CLIENT_KEY=
# 시크릿 키 — 서버 전용, 절대 NEXT_PUBLIC_ 금지
TOSS_SECRET_KEY=

# 정기 청구 cron 보호용 시크릿 (임의의 긴 랜덤 문자열)
BILLING_CRON_SECRET=

# ─── 사이트 ─────────────────────────────────────────────────
# 배포 도메인 (예: https://ateflo.com). OAuth 리다이렉트 등에 사용.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
